							"typeProperties": {
								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "SELECT\t\t\t\tMAX(S.InsertedDate) 'MaxDate'\nFROM\t\t\t\tReportingDB.DBO.StagingOrders S",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
