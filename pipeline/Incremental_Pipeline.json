								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "SELECT S.StagingOrderID AS 'OrderID',S.CustomerName,S.ProductName,S.Quantity,S.OrderAmount ,S.InsertedDate\nFROM\t\t\t\tReportingDB.DBO.StagingOrders S\n",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
